---
import Header from "../components/Header.astro";
import Nav from "../components/Nav.astro";
import "../styles/global.css";

const allPosts = await Astro.glob("./posts/*.md");
const sortedPosts = allPosts.sort((a, b) => {
	const dateA = a.file.split("/").pop()?.substring(0, 10) || "";
	const dateB = b.file.split("/").pop()?.substring(0, 10) || "";
	return dateB.localeCompare(dateA);
});

const categories = [
	...new Set(sortedPosts.map((post) => post.frontmatter.category)),
];
const postsList = categories.map((category) => {
	return {
		category,
		posts: sortedPosts.filter(
			(post) => post.frontmatter.category === category,
		),
	};
});
---

<!doctype html>
<html lang="ko">
	<Header pageTitle="BK's Blog" description="읽고 배우고 씁니다. 새로운 것을 배우는 것을 좋아합니다. MLOps Engineer로 일하며 기술 블로그를 운영하고 있습니다." />
	<body>
		<div class="max-w-screen-sm mx-auto min-h-screen px-4 sm:px-0 pb-20">
			<Nav />
			<main id="main-content">
				<section class="mb-12 sm:mb-16 font-serif">
					<h1 class="text-xl font-bold font-sans mb-4">강병규 | BK Kang</h1>
					<p class="leading-relaxed">읽고 배우고 씁니다. 새로운 것을 배우는 것을 좋아합니다.</p>
					<p class="leading-relaxed">지금은 버즈빌에서 MLOps Engineer로 일하고 있습니다.</p>
				</section>
				{
					postsList.map(({ category, posts }) => (
						<section class="font-serif flex flex-col sm:flex-row gap-4 sm:gap-8 mb-8 sm:mb-10">
							<a href={`/category/${category}`} class="font-semibold w-full sm:w-1/3 text-gray-600 hover:text-black transition-colors flex-shrink-0">
								{category}
							</a>
							<ul class="w-full">
								{posts.slice(0, 3).map((post) => (
									<li class="mb-1">
										<a href={post.url} class="hover:bg-gray-100 transition-colors duration-200 rounded py-1.5 px-2 -mx-2 inline-block">
											{post.frontmatter.title}
										</a>
									</li>
								))}
							</ul>
						</section>
					))
				}
				<a href="/posts" class="font-serif text-gray-500 hover:text-black transition-colors py-2 inline-block">
					모든 글 보기 →
				</a>
			</main>
		</div>
	</body>
</html>
