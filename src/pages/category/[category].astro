---
import Header from "../../components/Header.astro";
import Nav from "../../components/Nav.astro";
import "../../styles/global.css";
import { groupPostsByYear } from "../../scripts/posts";

export async function getStaticPaths() {
    const allPosts = await Astro.glob("../posts/*.md");
    const categories = [...new Set(allPosts.map((post) => post.frontmatter.category))];

    return categories.map((category) => ({
        params: { category },
        props: { posts: allPosts },
    }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
const filteredPosts = posts.filter(
    (post) => post.frontmatter.category === category,
);
const groupedPosts = groupPostsByYear(filteredPosts);
---

<!doctype html>
<html lang="ko">
    <Header pageTitle={category} description={`${category} 카테고리의 블로그 포스트 목록입니다.`} />
    <body>
        <div class="max-w-screen-sm mx-auto min-h-screen px-4 sm:px-0 pb-20">
            <Nav />
            <main id="main-content">
                <h1 class="text-xl font-bold font-sans mb-8 sm:mb-12">{category}</h1>
                <div class="font-serif">
                    {
                        Object.keys(groupedPosts)
                            .sort((a, b) => b - a)
                            .map((year) => (
                                <div class="flex flex-col sm:flex-row pt-6 sm:pt-8">
                                    <h2 class="text-gray-500 font-semibold text-sm sm:w-20 flex-shrink-0 mb-2 sm:mb-0 sm:pt-1.5">{year}</h2>
                                    <ul class="flex-grow min-w-0">
                                        {groupedPosts[year].map((post, index) => (
                                            <li class={`flex flex-col sm:flex-row sm:justify-between min-w-0 ${index > 0 ? 'pt-4 sm:pt-6' : ''}`}>
                                                <a href={post.url} class="break-words hover:bg-gray-100 transition-colors duration-200 rounded py-1.5 px-2 -mx-2 mb-1 sm:mb-0 sm:mr-4">
                                                    {post.frontmatter.title}
                                                </a>
                                                <p class="text-gray-400 text-xs sm:text-sm shrink-0 px-2 sm:px-0">
                                                    {post.frontmatter.pubDate.slice(5, 10)}
                                                </p>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            ))
                    }
                </div>
            </main>
        </div>
    </body>
</html>
